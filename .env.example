# Meta WhatsApp Business
VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
PHONE_NUMBER_ID=

# OpenAI
OPENAI_API_KEY=

# Firebase (JSON completo del service account, en una sola linea)
FIREBASE_SERVICE_ACCOUNT=
# No requerida por ahora: los adjuntos (imagen/documento) no se almacenan todavia
# (Firebase Storage es de pago y se evaluara mas adelante si es necesario).
FIREBASE_STORAGE_BUCKET=

# Azure AD / Microsoft Graph (Planner)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Solo para scripts/poblarClientesYResponsables.js
GROUP_ID=

# Microsoft Teams - Incoming Webhook (app "Workflows", NO Conectores clasicos - estan
# retirados) del canal donde se publican los avisos de tareas por vencer.
TEAMS_WEBHOOK_URL=

PORT=3000
